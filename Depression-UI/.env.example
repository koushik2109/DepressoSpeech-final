# ── DepressoSpeech Frontend Configuration ──
# Copy this file to .env (or .env.local) and fill in values.

# ─────────────────────────────────────────────────────────────
# API BASE URL
# Development  : leave blank → Vite proxies /api to localhost:8000
# Production   : set to the deployed backend URL (no trailing slash)
# ─────────────────────────────────────────────────────────────
VITE_API_BASE_URL=
# Production example:
# VITE_API_BASE_URL=https://your-backend.railway.app/api/v1

# ─────────────────────────────────────────────────────────────
# DEV PROXY TARGET  (only used by the Vite dev server)
# ─────────────────────────────────────────────────────────────
VITE_BACKEND_URL=http://localhost:8000

# ─────────────────────────────────────────────────────────────
# GOOGLE OAUTH
# Get your client ID from https://console.cloud.google.com/apis/credentials
# ─────────────────────────────────────────────────────────────
VITE_GOOGLE_CLIENT_ID=
