# ── MindScope Backend Configuration ──
# Copy this file to .env and fill in values before running.

# ─────────────────────────────────────────────────────────────
# APPLICATION
# ─────────────────────────────────────────────────────────────
APP_ENV=development          # development | production
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
API_V1_PREFIX=/api/v1

# ─────────────────────────────────────────────────────────────
# DATABASE
# dev  : SQLite  (default, zero-config)
# prod : PostgreSQL  — set DATABASE_URL to your hosted DB URL
# ─────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./mindscope.db
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/mindscope
DATABASE_ECHO=false

# ─────────────────────────────────────────────────────────────
# JWT AUTH  — MUST be changed before deployment
# ─────────────────────────────────────────────────────────────
JWT_SECRET_KEY=CHANGE_ME_TO_A_RANDOM_64_CHAR_STRING
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=480
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ─────────────────────────────────────────────────────────────
# CORS  — add your deployed frontend URL here
# ─────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000","http://127.0.0.1:5173"]
# Production example:
# CORS_ORIGINS=["https://your-app.netlify.app","https://your-domain.com"]

# ─────────────────────────────────────────────────────────────
# FILE STORAGE
# STORAGE_PROVIDER=local   → files stored on local disk (dev default)
# STORAGE_PROVIDER=s3      → files stored in AWS S3 / compatible object store
# ─────────────────────────────────────────────────────────────
STORAGE_PROVIDER=local
STORAGE_LOCAL_PATH=./storage/audio
AUDIO_MAX_FILE_SIZE_MB=100
VIDEO_MAX_FILE_SIZE_MB=500
AUDIO_ALLOWED_EXTENSIONS=.wav,.mp3,.flac,.ogg,.m4a,.webm
VIDEO_ALLOWED_EXTENSIONS=.mp4,.avi,.mov,.mkv,.webm
MULTIMODAL_STORAGE_PATH=./storage/multimodal

# S3 settings (only required when STORAGE_PROVIDER=s3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=
S3_KEY_PREFIX=audio/
S3_ENDPOINT_URL=         # Leave blank for AWS; set for Minio/R2/Backblaze
S3_URL_EXPIRY_SECONDS=3600

# ─────────────────────────────────────────────────────────────
# ML MODEL
# ─────────────────────────────────────────────────────────────
ML_MODEL_URL=http://localhost:8001
ML_MODEL_PATH=../Model/checkpoints/best_model.pt
ML_CONFIG_PATH=../Model/configs/inference_config.yaml
ML_DEVICE=auto

# Inference result cache (in-memory; set REDIS_URL for distributed cache)
ML_CACHE_TTL_SECONDS=3600
ML_CACHE_MAX_ENTRIES=500
REDIS_URL=               # e.g. redis://localhost:6379/0  (optional)

# ─────────────────────────────────────────────────────────────
# ADMIN DEFAULTS
# ─────────────────────────────────────────────────────────────
ADMIN_DEFAULT_EMAIL=admin@mindscope.ai
ADMIN_DEFAULT_PASSWORD=Admin@2026!

# ─────────────────────────────────────────────────────────────
# SMTP  (for OTP verification emails)
# ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
OTP_EXPIRE_MINUTES=10

# ─────────────────────────────────────────────────────────────
# GOOGLE OAUTH
# Get your client ID from https://console.cloud.google.com/apis/credentials
# ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
